{
  "name": "vil-assistant",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --config vitest.ci.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "pnpm test && pnpm test:e2e",
    "preflight": "pnpm typecheck && pnpm lint && pnpm test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit:observatory": "echo 'Visita https://observatory.mozilla.org y analiza tu URL desplegada'",
    "audit:all": "pnpm typecheck && pnpm test && pnpm build",
    "sonar": "sonar-scanner",
    "jscpd": "jscpd",
    "jscpd:report": "jscpd --output reports/duplication --reporters html",
    "load:test": "k6 run tests/load/chat-load.test.js",
    "load:test:staging": "k6 run -e BASE_URL=https://vil-assistant.vercel.app tests/load/chat-load.test.js"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@tailwindcss/postcss": "^4.3.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.40.0",
    "lucide-react": "^0.546.0",
    "next": "^16.2.6",
    "postcss": "^8.5.15",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "shadcn": "^4.9.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "16.3.0-canary.45",
    "@playwright/test": "^1.60.0",
    "@sentry/nextjs": "^10.55.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.14.0",
    "@types/react": "19.2.15",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "jscpd": "^5.0.9",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": "24.x"
  }
}
